<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.vitalsa.controller.FacturacionController" style="-fx-background-color: #F8F9FA;" spacing="20">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header -->
    <VBox spacing="5">
        <Label text="Gestión de Facturación" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
        <Label text="Monitoreo de ingresos, cobros y auditoria de comprobantes." style="-fx-text-fill: #7F8C8D;"/>
    </VBox>

    <!-- KPI Cards -->
    <HBox spacing="20">
        <!-- Card 1 -->
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #EAECEE; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="FACTURACIÓN TOTAL (MES)" style="-fx-text-fill: #7F8C8D; -fx-font-size: 10px; -fx-font-weight: bold;" wrapText="true" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>
            <Label fx:id="lblTotalMes" text="0,00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            <Label fx:id="lblCrecimientoPct" text="+0.0% vs mes anterior" style="-fx-text-fill: #27AE60; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Card 2 -->
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #EAECEE; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="CUENTAS POR COBRAR" style="-fx-text-fill: #7F8C8D; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblCuentasPorCobrar" text="0,00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            <Label fx:id="lblFacturasPendientes" text="0 facturas pendientes" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px;"/>
        </VBox>

        <!-- Card 3 -->
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #EAECEE; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="PAGOS VERIFICADOS" style="-fx-text-fill: #7F8C8D; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblPagosVerificados" text="0 / 0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            <ProgressBar fx:id="pbPagos" progress="0.0" prefWidth="150" prefHeight="8" style="-fx-accent: #1ABC9C;"/>
        </VBox>

        <!-- Card 4 -->
        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #EAECEE; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="TOTAL COBRADO (HOY)" style="-fx-text-fill: #7F8C8D; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblCobradoHoy" text="0,00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            <Label text="Actualizado hace 5 min" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- Filters Bar and Actions -->
    <HBox spacing="20" alignment="CENTER_LEFT">
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 10 15; -fx-background-radius: 8; -fx-border-color: #EAECEE; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.02), 5, 0, 0, 1);" maxWidth="600">
            <org.kordamp.ikonli.javafx.FontIcon iconLiteral="fas-filter" iconSize="12" iconColor="#64748B" />
            <javafx.scene.control.ComboBox fx:id="cmbFiltroEstado" promptText="Todos" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-text-fill: #334155; -fx-pref-width: 150;" />
            <javafx.scene.control.TextField fx:id="txtBuscar" promptText="Buscar factura, cliente..." style="-fx-pref-width: 250; -fx-padding: 5; -fx-background-radius: 4; -fx-border-color: #CBD5E1; -fx-border-radius: 4;" />
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnGenerarResumen" onAction="#generarResumenDiario" text="GENERAR RESUMEN DIARIO" style="-fx-background-color: #154360; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>

    <!-- Main Content -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        
        <!-- Left Column: Table -->
        <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #EAECEE; -fx-border-radius: 8;" HBox.hgrow="ALWAYS" spacing="15">
            <HBox alignment="CENTER_LEFT">
                <Label text="Facturas Emitidas Recientemente" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
            </HBox>
            
            <TableView fx:id="tablaFacturas" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent; -fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="colId" text="ID FACTURA" prefWidth="120"/>
                    <TableColumn fx:id="colCliente" text="CLIENTE" prefWidth="250"/>
                    <TableColumn fx:id="colEstado" text="ESTADO" prefWidth="120"/>
                    <TableColumn fx:id="colAcciones" text="ACCIONES" prefWidth="100"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Right Column: Actions -->
        <VBox spacing="20" minWidth="300" maxWidth="300">
            <VBox style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #EAECEE; -fx-border-radius: 8;" spacing="15">
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10;">
                    <Label text="Registrar Pago" style="-fx-text-fill: #2C3E50; -fx-font-weight: bold; -fx-font-size: 16px;"/>
                </HBox>

                <VBox spacing="5">
                    <Label text="Cliente o Factura" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px;"/>
                    <TextField fx:id="txtBuscadorFactura" promptText="Ej: 001-000452" style="-fx-padding: 8; -fx-background-radius: 4; -fx-border-color: #D5D8DC; -fx-border-radius: 4;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Método de Pago" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px;"/>
                    <ComboBox fx:id="cmbMetodoPago" maxWidth="Infinity" style="-fx-background-color: white; -fx-border-color: #D5D8DC; -fx-border-radius: 4; -fx-padding: 4;"/>
                </VBox>

                <Button fx:id="btnProcesarPago" onAction="#procesarPago" text="PROCESAR PAGO" maxWidth="Infinity" style="-fx-background-color: #D6EAF8; -fx-text-fill: #154360; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 4; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </HBox>

</VBox>
