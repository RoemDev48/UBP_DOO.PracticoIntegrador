<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.vitalsa.controller.ClienteModalController" spacing="15" prefWidth="450" style="-fx-background-color: white; -fx-padding: 25;">
    <Label fx:id="lblTitulo" text="Registrar Nuevo Cliente" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0D1B2A;" />
    
    <VBox spacing="5">
        <Label text="Tipo de Cliente:" />
        <ComboBox fx:id="cmbTipoCliente" prefWidth="Infinity" promptText="Seleccionar..."/>
    </VBox>

    <VBox spacing="5">
        <Label text="Nombre / Razón Social:" />
        <TextField fx:id="txtNombre" promptText="Ingrese el nombre" />
    </VBox>

    <VBox spacing="5">
        <Label text="Documento (DNI/CUIT):" />
        <TextField fx:id="txtDocumento" promptText="Ingrese documento" />
    </VBox>

    <HBox spacing="10">
        <VBox spacing="5" HBox.hgrow="SOMETIMES" prefWidth="140">
            <Label text="Zona:" />
            <ComboBox fx:id="cmbZona" prefWidth="Infinity" promptText="..." />
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Calle:" />
            <TextField fx:id="txtDireccion" promptText="Nombre calle" />
        </VBox>
        <VBox spacing="5" HBox.hgrow="SOMETIMES" prefWidth="80">
            <Label text="N°:" />
            <TextField fx:id="txtNumeracion" promptText="Ej: 120" />
        </VBox>
    </HBox>

    <HBox spacing="10">
        <VBox spacing="5" HBox.hgrow="SOMETIMES" prefWidth="140">
            <Label text="Tipo:" />
            <ComboBox fx:id="cmbTipoTelefono" prefWidth="Infinity" promptText="Elegir..." />
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Teléfono:" />
            <TextField fx:id="txtTelefono" promptText="Ej: 351..." />
        </VBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" VBox.vgrow="ALWAYS">
        <padding><Insets top="20"/></padding>
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#cancelar" style="-fx-background-color: #E2E8F0; -fx-text-fill: #1A202C; -fx-padding: 8 15;" />
        <Button fx:id="btnGuardar" text="Guardar Cliente" onAction="#guardarCliente" style="-fx-background-color: #0056b3; -fx-text-fill: white; -fx-padding: 8 15; -fx-font-weight: bold;" />
    </HBox>
</VBox>
