<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.vitalsa.controller.PrecioModalController" spacing="20" style="-fx-background-color: white; -fx-padding: 30;" prefWidth="350">
    
    <Label text="Modificar Precio" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
    
    <VBox spacing="5" style="-fx-background-color: #F8FAFC; -fx-padding: 10; -fx-background-radius: 5;">
        <Label text="PRODUCTO SELECCIONADO" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;" />
        <Label fx:id="lblNombreProducto" text="Cargando..." style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" wrapText="true" />
    </VBox>

    <VBox spacing="5">
        <Label text="Nuevo Precio Unitario ($)" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
        <TextField fx:id="txtPrecio" promptText="0.00" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #0D9488; -fx-border-radius: 5; -fx-font-size: 16px; -fx-font-weight: bold;" />
    </VBox>

    <Region VBox.vgrow="ALWAYS" />
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cerrar" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand;" />
        <Button text="Actualizar" onAction="#guardar" style="-fx-background-color: #0D9488; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5; -fx-cursor: hand;" />
    </HBox>

</VBox>
