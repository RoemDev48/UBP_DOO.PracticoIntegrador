<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.vitalsa.controller.ProductoModalController" spacing="20" style="-fx-background-color: white; -fx-padding: 30;" prefWidth="400">
    
    <Label text="Alta de Producto" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" />
    <Label text="Ingresa los datos del nuevo producto y su stock inicial." style="-fx-font-size: 13px; -fx-text-fill: #64748B;" wrapText="true" />
    
    <VBox spacing="5">
        <Label text="Categoría (Línea de Producto)" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
        <TextField fx:id="txtCategoria" promptText="Ej: Suplementos" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #CBD5E1; -fx-border-radius: 5;" />
    </VBox>

    <VBox spacing="5">
        <Label text="Nombre de la Presentación" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
        <TextField fx:id="txtNombre" promptText="Ej: Vitamina C 1000mg" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #CBD5E1; -fx-border-radius: 5;" />
    </VBox>

    <HBox spacing="15">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Precio Unitario ($)" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
            <TextField fx:id="txtPrecio" promptText="0.00" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #CBD5E1; -fx-border-radius: 5;" />
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Stock Inicial" style="-fx-font-weight: bold; -fx-text-fill: #334155;" />
            <TextField fx:id="txtStock" promptText="0" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #CBD5E1; -fx-border-radius: 5;" />
        </VBox>
    </HBox>

    <Region VBox.vgrow="ALWAYS" />
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cerrar" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand;" />
        <Button text="Guardar Producto" onAction="#guardar" style="-fx-background-color: #0056b3; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5; -fx-cursor: hand;" />
    </HBox>

</VBox>
