<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.vitalsa.controller.LogisticaController" style="-fx-background-color: #F0F2F5;" spacing="20">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- LEFT PANEL: Pedidos Pendientes & Distribuidores -->
    <VBox spacing="20" prefWidth="320" minWidth="320" maxWidth="320">
        
        <!-- Pedidos Pendientes -->
        <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Pedidos Pendientes" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495E;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblUrgentCount" text="15 Urgent" style="-fx-background-color: #FADBD8; -fx-text-fill: #C0392B; -fx-padding: 3 8; -fx-background-radius: 10; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            </HBox>
            <ListView fx:id="listPedidosPendientes" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-control-inner-background: #F0F2F5;"/>
            <Button fx:id="btnAsignarSeleccionados" text="Asignar Seleccionados" onAction="#asignarSeleccionados" maxWidth="Infinity" style="-fx-background-color: #1A5276; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </VBox>
        
        <!-- Gestión Distribuidores -->
        <VBox spacing="10" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="Gestión Distribuidores" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495E;"/>
            <ListView fx:id="listDistribuidores" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-control-inner-background: white;"/>
        </VBox>

    </VBox>

    <!-- MAIN PANEL: Seguimiento Envíos -->
    <VBox spacing="20" HBox.hgrow="ALWAYS">
        
        <!-- Top Box: Tabla -->
        <VBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT">
                <Label text="Seguimiento de Envíos en Tránsito" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495E;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Filtrar por Estado" style="-fx-background-color: white; -fx-border-color: #D5D8DC; -fx-border-radius: 4; -fx-padding: 5 15; -fx-text-fill: #5D6D7E; -fx-cursor: hand;"/>
            </HBox>
            
            <TableView fx:id="tablaTransito" VBox.vgrow="ALWAYS" style="-fx-border-color: #EAEDED; -fx-background-color: white;">
                <columns>
                    <TableColumn fx:id="colId" text="ID PEDIDO" prefWidth="90"/>
                    <TableColumn fx:id="colDistribuidor" text="DISTRIBUIDOR" prefWidth="180"/>
                    <TableColumn fx:id="colZona" text="RUTA / ZONA" prefWidth="150"/>
                    <TableColumn fx:id="colEstado" text="ESTADO" prefWidth="120"/>
                    <TableColumn fx:id="colAcciones" text="ACCIONES DE CONTROL" prefWidth="250"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Bottom Box: Empty Placeholder -->
        <VBox prefHeight="250" style="-fx-background-color: white; -fx-border-color: #E5E8E8; -fx-border-radius: 8; -fx-background-radius: 8;">
            <!-- Placeholder para mapa o detalles -->
        </VBox>

    </VBox>

</HBox>
